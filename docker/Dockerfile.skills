# nemo-evaluator + NeMo Skills
# For: skills:// benchmarks (mmlu-pro, gsm8k, math, etc.)
ARG BASE_IMAGE=nemo-evaluator:latest
FROM ${BASE_IMAGE}

WORKDIR /app

COPY docker/skills-uv-overrides.txt /tmp/skills-uv-overrides.txt

RUN pip install --no-cache-dir "uv==0.6.1" \
    && uv pip install --system --break-system-packages --no-cache \
        --overrides /tmp/skills-uv-overrides.txt \
        ".[scoring,stats,skills]"

CMD ["nel", "--help"]
