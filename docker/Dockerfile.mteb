# nemo-evaluator + MTEB
# For: mteb:// embedding benchmarks (STSBenchmark, etc.)
FROM python:3.11-slim AS base

WORKDIR /app
RUN pip install --no-cache-dir --upgrade pip

COPY pyproject.toml README.md ./
COPY src/ src/

RUN pip install --no-cache-dir ".[scoring,stats,mteb]"

ENV PYTHONUNBUFFERED=1
ENTRYPOINT ["nel"]
CMD ["--help"]
